# Hetzner VPS SSH target (user@ip)
HETZNER_HOST=root@YOUR_HETZNER_IP

# Cloudflare Pages project name
CLOUDFLARE_PAGES_PROJECT=tron-with-the-wind

# Production Colyseus server URL (WebSocket over Cloudflare proxy)
COLYSEUS_PROD_URL=wss://tron-server.afspies.com

# Staging Colyseus server URL
COLYSEUS_STAGING_URL=wss://tron-staging-server.afspies.com
