# Stage 1: Build
FROM node:20-alpine AS build
WORKDIR /app

ARG GIT_BRANCH=""

# Copy package manifests for layer caching
COPY package.json package-lock.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/game-core/package.json packages/game-core/
COPY apps/web/package.json apps/web/
# Stub for server workspace so npm install doesn't fail
RUN mkdir -p apps/server && echo '{"name":"@tron/server","version":"0.0.0"}' > apps/server/package.json
RUN npm install

# Copy source
COPY packages/ packages/
COPY apps/web/ apps/web/

ENV GIT_BRANCH=${GIT_BRANCH}
RUN npm run build --workspace=apps/web

# Stage 2: Serve
FROM nginx:alpine
COPY --from=build /app/apps/web/dist /usr/share/nginx/html

# SPA fallback: serve index.html for all routes
RUN printf 'server {\n  listen 80;\n  location / {\n    root /usr/share/nginx/html;\n    try_files $uri $uri/ /index.html;\n  }\n}\n' > /etc/nginx/conf.d/default.conf

EXPOSE 80
